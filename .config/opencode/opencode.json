{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "uvx",
        "kubernetes-mcp-server@latest",
        "--kubeconfig",
        "/home/joshua/.kube/k3s.yaml"
      ],
      "enabled": false
    },
    "grafana": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-grafana"
      ],
      "environment": {
        "GRAFANA_URL": "https://grafana.secmet.co",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      },
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    },
    "atlassian": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "mcp-remote",
        "https://mcp.atlassian.com/v1/mcp"
      ],
      "enabled": false
    }
  },
  "permission": {
    "bash": {
      "*git commit *": "ask",
      "*git push *": "ask"
    },
    "glob": {
      "**/node_modules/**": "ask",
      "**/.venv/**": "ask",
      "**/.nox/**": "ask",
      "**/.git/**": "ask"
    },
    "grep": {
      "**/node_modules/**": "ask",
      "**/.venv/**": "ask",
      "**/.nox/**": "ask",
      "**/.git/**": "ask"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 3000
  },
  "share": "disabled"
}