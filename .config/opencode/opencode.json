{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "uvx",
        "kubernetes-mcp-server@latest",
        "--kubeconfig",
        "/home/joshua/.kube/k3s.yaml"
      ],
      "enabled": false
    },
    "grafana": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-grafana"
      ],
      "environment": {
        "GRAFANA_URL": "https://grafana.secmet.co",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      },
      "enabled": false
    }
  },
  "agent": {
    "code-review": {
      "description": "Reviews code for best practices and potential issues",
      "prompt": "You are a code reviewer. Focus on security, performance, maintainability, and thread safety. Present issues in a concise and easy to read format. Please limit output to the user",
      "tools": {
        "write": false,
        "edit": false
      }
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 5000
  }
}