{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "mcp": {
    "kubernetes": {
      "type": "local",
      "command": [
        "uvx",
        "kubernetes-mcp-server@latest",
        "--kubeconfig",
        "{env:KUBECONFIG}"
      ],
      "enabled": false
    },
    "grafana": {
      "type": "local",
      "command": [
        "uvx",
        "mcp-grafana"
      ],
      "environment": {
        "GRAFANA_URL": "https://grafana.secmet.co",
        "GRAFANA_SERVICE_ACCOUNT_TOKEN": "${env:GRAFANA_SERVICE_ACCOUNT_TOKEN}"
      },
      "enabled": false
    },
    "chrome-devtools": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "enabled": false
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 5000
  }
}
