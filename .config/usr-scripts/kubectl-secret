#!/usr/bin/env bash

set -euo pipefail

if ! command -v kubectl >/dev/null 2>&1; then
  echo "kubectl is required" >&2
  exit 1
fi

if ! command -v fzf >/dev/null 2>&1; then
  echo "fzf is required" >&2
  exit 1
fi

namespace="${1:-}"
if [[ -z "${namespace}" ]]; then
  namespace="$(kubectl config view --minify -o jsonpath='{..namespace}' 2>/dev/null || true)"
fi
if [[ -z "${namespace}" ]]; then
  namespace="default"
fi

secret_name="$(kubectl get secrets -n "${namespace}" -o name | sed 's|^secret/||' | fzf --prompt "secret (${namespace})> ")"
if [[ -z "${secret_name}" ]]; then
  echo "No secret selected" >&2
  exit 1
fi

key_name="$(kubectl get secret "${secret_name}" -n "${namespace}" -o go-template='{{range $k, $v := .data}}{{printf "%s\n" $k}}{{end}}' | fzf --prompt "key (${secret_name})> ")"
if [[ -z "${key_name}" ]]; then
  echo "No key selected" >&2
  exit 1
fi

b64_value="$(kubectl get secret "${secret_name}" -n "${namespace}" -o jsonpath="{.data.${key_name}}")"
if [[ -z "${b64_value}" ]]; then
  echo "Selected key is empty" >&2
  exit 1
fi

copy_to_clipboard() {
  if command -v wl-copy >/dev/null 2>&1; then
    wl-copy
    return 0
  fi

  if command -v xclip >/dev/null 2>&1; then
    xclip -selection clipboard
    return 0
  fi

  if command -v xsel >/dev/null 2>&1; then
    xsel --clipboard --input
    return 0
  fi

  if command -v pbcopy >/dev/null 2>&1; then
    pbcopy
    return 0
  fi

  return 1
}

if ! copy_to_clipboard < <(printf '%s' "${b64_value}" | base64 --decode); then
  echo "No clipboard tool found (wl-copy, xclip, xsel, pbcopy)" >&2
  exit 1
fi

echo "Copied ${secret_name}:${key_name} to clipboard"
